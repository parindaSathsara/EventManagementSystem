{
  "meta": {
    "name": "EventSocial UI Tokens",
    "version": "1.0.0",
    "theme": "MonochromeDualAccent",
    "source": "RequirementDocs/eventsocial_full_requirements.md"
  },
  "color": {
    "bg": {
      "strong": "#050505",
      "default": "#0C0C0E",
      "soft": "#141418"
    },
    "surface": {
      "1": "#1A1B1F",
      "2": "#22232A",
      "3": "#2A2D35"
    },
    "line": {
      "subtle": "#2E313A",
      "strong": "#4A4E5A"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#C8CBD3",
      "muted": "#9CA2AF",
      "inverse": "#0B0C10"
    },
    "paper": {
      "default": "#FFFFFF",
      "soft": "#F4F5F7",
      "line": "#DBDEE5",
      "ink": "#0B0C10",
      "inkMuted": "#515866"
    },
    "accent": {
      "pink": "#FF5482",
      "green": "#00FFA1"
    },
    "state": {
      "ok": "#00FFA1",
      "warn": "#FFB020",
      "error": "#FF5C7A",
      "info": "#6BA8FF"
    }
  },
  "typography": {
    "fontFamily": {
      "heading": "Sora, sans-serif",
      "body": "Manrope, sans-serif"
    },
    "size": {
      "displayLg": 48,
      "displayMd": 40,
      "h1": 32,
      "h2": 28,
      "h3": 24,
      "h4": 20,
      "title": 18,
      "bodyLg": 16,
      "bodyMd": 14,
      "bodySm": 13,
      "caption": 12
    },
    "lineHeight": {
      "displayLg": 56,
      "displayMd": 48,
      "h1": 40,
      "h2": 36,
      "h3": 32,
      "h4": 28,
      "title": 26,
      "bodyLg": 24,
      "bodyMd": 22,
      "bodySm": 20,
      "caption": 18
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    }
  },
  "space": {
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64
  },
  "radius": {
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20,
    "pill": 999
  },
  "border": {
    "hairline": 1,
    "emphasis": 2
  },
  "elevation": {
    "surface": "0 0 0 1px rgba(255,255,255,0.04)",
    "raised": "0 6px 24px rgba(0,0,0,0.35)",
    "overlay": "0 12px 36px rgba(0,0,0,0.45)"
  },
  "motion": {
    "duration": {
      "fast": 120,
      "base": 180,
      "slow": 240
    },
    "easing": {
      "enter": "cubic-bezier(0.2, 0, 0, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)"
    }
  }
