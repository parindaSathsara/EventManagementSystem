(function ($) {
  "use strict";

  var TZ = "Asia/Colombo";
  var LOCAL_EVENT_IMAGES = [
    "images/event-posters/poster-01.jpg",
    "images/event-posters/poster-02.jpg",
    "images/event-posters/poster-03.jpg",
    "images/event-posters/poster-04.jpg",
    "images/event-posters/poster-05.jpg",
    "images/event-posters/poster-06.jpg",
    "images/event-posters/poster-07.jpg",
    "images/event-posters/poster-08.jpg",
    "images/event-posters/poster-09.jpg",
    "images/event-posters/poster-10.jpg",
    "images/event-posters/poster-11.jpg",
    "images/event-posters/poster-12.jpg",
    "images/event-posters/poster-13.jpg",
    "images/event-posters/poster-14.jpg",
    "images/event-posters/poster-15.jpg",
    "images/event-posters/poster-16.jpg",
    "images/event-posters/poster-17.jpg",
    "images/event-posters/poster-18.jpg",
    "images/event-posters/poster-19.jpg",
    "images/event-posters/poster-20.jpg",
    "images/event-posters/poster-21.jpg",
    "images/event-posters/poster-22.jpg",
    "images/event-posters/poster-23.jpg",
   
  ];

  var state = {
    view: "month",
    cursor: new Date(),
    events: [],
    filters: {
      q: "",
      category: "",
      location: "",
      datePreset: "",
    },
  };

  var $eventsRoot = null;
  var calendarShells = [];

  function initCalendarShells() {
    $eventsRoot = $("#calendar-events-root");
    calendarShells = [];
    $(".calendar-shell").each(function () {
      calendarShells.push({ $shell: $(this) });
    });
  }

  function syncToolbarUI(titleText) {
    var dimStepper =
      (state.view === "month" || state.view === "day") && anyFilterActive();
    calendarShells.forEach(function (entry) {
      var $shell = entry.$shell;
      $shell.find(".calendar-view-switch .cal-btn").removeClass("active");
      $shell
        .find('.calendar-view-switch .cal-btn[data-view="' + state.view + '"]')
        .addClass("active");
      if (titleText !== undefined) {
        $shell.find(".calendar-title-strip").text(titleText);
      }
      $shell.find(".calendar-stepper").toggleClass("calendar-stepper--filter-mode", dimStepper);
    });
  }

  function scrollToEventsContent() {
    var target = document.getElementById("calendar-events-root");
    if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function setView(view, fromBottom) {
    state.view = view;
    renderEvents();
    if (fromBottom) scrollToEventsContent();
  }

  function stepCursor(view, direction) {
    var delta = direction === "next" ? 1 : -1;
    if (view === "day") state.cursor.setDate(state.cursor.getDate() + delta);
    else if (view === "year") state.cursor.setFullYear(state.cursor.getFullYear() + delta);
    else state.cursor.setMonth(state.cursor.getMonth() + delta);
  }

  function eventRealIndex(item) {
    if (!item) return -1;
    var i = state.events.indexOf(item);
    if (i >= 0) return i;
    if (item.id) {
      for (var j = 0; j < state.events.length; j++) {
        if (state.events[j] && state.events[j].id === item.id) return j;
      }
    }
    return -1;
  }

  function findEventAtIndex(idx) {
    if (typeof idx !== "number" || isNaN(idx) || idx < 0) return null;
    return state.events[idx] || null;
  }

  function findEventByKey(idx, eventId) {
    var item = findEventAtIndex(idx);
    if (item) return item;
    if (!eventId) return null;
    for (var i = 0; i < state.events.length; i++) {
      if (state.events[i] && state.events[i].id === eventId) return state.events[i];
    }
    return null;
  }

  function uniqueLocationsFromEvents(items) {
    var set = {};
    (items || []).forEach(function (it) {
      var loc = (it.location || "").trim();
      if (!loc) return;
      loc.split(/[,|]/).forEach(function (chunk) {
        var t = chunk.trim();
        if (t.length > 1) set[t] = true;
      });
    });
    return Object.keys(set).sort(function (a, b) {
      return a.localeCompare(b);
    });
  }

  function populateLocationFilter(items) {
    var sel = document.getElementById("filter-location");
    if (!sel) return;
    var preserve = sel.options[0] ? sel.options[0].textContent : "All locations";
    var saved = sel.value || "";
    sel.innerHTML = "";
    var blank = document.createElement("option");
    blank.value = "";
    blank.textContent = preserve;
    sel.appendChild(blank);
    uniqueLocationsFromEvents(items).forEach(function (city) {
      var opt = document.createElement("option");
      opt.value = city;
      opt.textContent = city;
      sel.appendChild(opt);
    });
    if (saved && Array.from(sel.options).some(function (o) { return o.value === saved; })) sel.value = saved;
  }

  function haystackText(item) {
    var raw = "";
    raw += item.summary || "";
    raw += " ";
    raw += item.description ? item.description.replace(/<[^>]+>/g, " ") : "";
    raw += " ";
    raw += item.location || "";
    var d = parseDescription(item.description || "");
    raw += " " + (d.artists || "") + " " + (d.type || "") + " " + (d.organiser || "");
    return raw.toLowerCase();
  }

  function passesQuery(item) {
    var q = (state.filters.q || "").trim().toLowerCase();
    if (!q) return true;
    var h = haystackText(item);
    var parts = q.split(/\s+/).filter(Boolean);
    for (var i = 0; i < parts.length; i++) {
      if (h.indexOf(parts[i]) === -1) return false;
    }
    return true;
  }

  function passesCategory(item) {
    var c = (state.filters.category || "").trim().toLowerCase();
    if (!c) return true;
    var h = haystackText(item);
    if (h.indexOf(c) !== -1) return true;
    if (c === "edm" && /edm|electronic|dance/i.test(h)) return true;
    if (c === "drum" && /drum|dnb|\b&\s*bass|bass\b/i.test(h)) return true;
    return false;
  }

  function passesLocation(item) {
    var want = (state.filters.location || "").trim().toLowerCase();
    if (!want) return true;
    var loc = (item.location || "").toLowerCase();
    return loc.indexOf(want) !== -1;
  }

  /* Sat 00:00 → Sun 23:59 relative to anchor (handles “this weekend”) */
  function thisWeekendRange(anchor) {
    var ref = new Date(anchor.getFullYear(), anchor.getMonth(), anchor.getDate());
    var dow = ref.getDay();
    var sat;
    if (dow === 6) sat = new Date(ref);
    else if (dow === 0) {
      sat = new Date(ref);
      sat.setDate(sat.getDate() - 1);
    } else {
      sat = new Date(ref);
      sat.setDate(sat.getDate() + (6 - dow));
    }
    var sun = new Date(sat);
    sun.setDate(sun.getDate() + 1);
    var start = new Date(sat.getFullYear(), sat.getMonth(), sat.getDate(), 0, 0, 0, 0);
    var end = new Date(sun.getFullYear(), sun.getMonth(), sun.getDate(), 23, 59, 59, 999);
    return { start: start, end: end };
  }

  function nextCalendarMonthBounds(anchor) {
    var start = new Date(anchor.getFullYear(), anchor.getMonth() + 1, 1, 0, 0, 0, 0);
    var end = new Date(anchor.getFullYear(), anchor.getMonth() + 2, 1, 0, 0, 0, 0);
    return { start: start, end: end };
  }

  function passesDatePreset(item) {
    var preset = (state.filters.datePreset || "").trim();
    if (!preset) return true;
    var start = getStartDate(item);
    if (!start) return false;
    var now = new Date();
    if (preset === "weekend") {
      var r = thisWeekendRange(now);
      return start >= r.start && start <= r.end;
    }
    if (preset === "next_month") {
      var nm = nextCalendarMonthBounds(now);
      return start >= nm.start && start < nm.end;
    }
    if (preset === "30d") {
      var until = new Date(now);
      until.setDate(until.getDate() + 30);
      return start >= now && start <= until;
    }
    if (preset === "season") {
      var longEnd = new Date(now);
      longEnd.setDate(longEnd.getDate() + 120);
      return start >= now && start <= longEnd;
    }
    return true;
  }

  function getFilteredEvents() {
    return (state.events || []).filter(function (item) {
      return passesQuery(item) && passesCategory(item) && passesLocation(item) && passesDatePreset(item);
    });
  }

  function anyFilterActive() {
    return !!(
      state.filters.q ||
      state.filters.category ||
      state.filters.location ||
      state.filters.datePreset
    );
  }

  function sortByStartDate(a, b) {
    return (getStartDate(a) || 0) - (getStartDate(b) || 0);
  }

  function readFiltersFromForm() {
    var qEl = document.getElementById("filter-q");
    var cEl = document.getElementById("filter-category");
    var lEl = document.getElementById("filter-location");
    var dEl = document.getElementById("filter-date");
    state.filters.q = qEl ? qEl.value.trim() : "";
    state.filters.category = cEl ? (cEl.value || "").trim().toLowerCase() : "";
    state.filters.location = lEl ? (lEl.value || "").trim() : "";
    state.filters.datePreset = dEl ? (dEl.value || "").trim() : "";
  }

  function updateFilterLiveStatus() {
    var status = document.getElementById("filter-status");
    if (!status) return;
    var total = (state.events || []).length;
    if (!total) {
      status.textContent = "";
      return;
    }
    var n = getFilteredEvents().length;
    status.textContent =
      n === total
        ? "Showing all " + total + " events"
        : "Showing " + n + " of " + total + " events matching your filters.";
  }

  var heroSearchBound = false;

  function bindHeroFilters($root) {
    if (heroSearchBound) return;
    var form = document.getElementById("hero-event-search");
    if (!form) return;
    heroSearchBound = true;

    function apply() {
      readFiltersFromForm();
      renderEvents();
      renderHeroSpotlight();
    }

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      apply();
      var ev = document.getElementById("events");
      if (ev) ev.scrollIntoView({ behavior: "smooth" });
    });

    var qEl = document.getElementById("filter-q");
    if (qEl) {
      var t;
      qEl.addEventListener("input", function () {
        clearTimeout(t);
        t = setTimeout(apply, 320);
      });
    }

    ["filter-category", "filter-location", "filter-date"].forEach(function (id) {
      var el = document.getElementById(id);
      if (el) el.addEventListener("change", apply);
    });
  }

  function formatHeroWhen(item) {
    return formatEventRange(item);
  }

  function renderHeroSpotlight() {
    var titleEl = document.getElementById("hero-feature-title");
    var metaEl = document.getElementById("hero-feature-meta");
    if (!titleEl || !metaEl) return;

    var pool = getFilteredEvents().length ? getFilteredEvents() : state.events;
    var now = new Date();
    var upcoming = (pool || [])
      .filter(function (it) {
        var d = getStartDate(it);
        return d && d >= now;
      })
      .sort(function (a, b) {
        return getStartDate(a) - getStartDate(b);
      });

    if (!upcoming.length) {
      titleEl.textContent = "Check the calendar";
      metaEl.innerHTML =
        '<div>No upcoming events match your filters. <strong>Adjust search</strong> or pick another month.</div>';
      var chipDead = document.getElementById("hero-feature-chip");
      if (chipDead) chipDead.textContent = "No matches";
      var ct = document.getElementById("hero-feature-cta");
      if (ct) {
        ct.setAttribute("disabled", "disabled");
        ct.removeAttribute("data-ev-idx");
        ct.textContent = "Book now";
      }
      return;
    }

    var ev = upcoming[0];
    var start = getStartDate(ev);
    titleEl.textContent = sanitizeDetailField(ev.summary) || "Upcoming event";
    var locHero = sanitizeDetailField(ev.location || "");
    var loc = escapeHtml(locHero || "Venue TBA");
    var when = escapeHtml(formatHeroWhen(ev));
    metaEl.innerHTML =
      "<div><strong>" + when + "</strong></div>" + '<div><span class="hero-loc">' + loc + "</span></div>";

    var chip = document.getElementById("hero-feature-chip");
    if (chip && start) {
      chip.textContent = start.toLocaleDateString("en-LK", {
        timeZone: TZ,
        weekday: "short",
        month: "short",
        day: "numeric",
      });
    } else if (chip) chip.textContent = "Next show";

    var cta = document.getElementById("hero-feature-cta");
    if (cta) {
      cta.textContent = "Book now";
      cta.removeAttribute("disabled");
      cta.setAttribute("data-ev-idx", String(eventRealIndex(ev)));
    }
  }

  function isMobile() {
    return window.innerWidth < 768;
  }

  function escapeHtml(s) {
    if (!s) return "";
    var div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  function getStartDate(item) {
    if (item.start?.dateTime) return new Date(item.start.dateTime);
    if (item.start?.date) return new Date(item.start.date + "T00:00:00");
    return null;
  }

  function getEndDate(item) {
    if (item.end?.dateTime) return new Date(item.end.dateTime);
    if (item.end?.date) return new Date(item.end.date + "T00:00:00");
    return null;
  }

  function formatEventRange(item) {
    var start = item.start || {};
    var end   = item.end   || {};
    if (start.dateTime) {
      var a = new Date(start.dateTime);
      var txt = a.toLocaleString("en-LK", { timeZone: TZ });
      if (end.dateTime) {
        txt += " \u2013 " + new Date(end.dateTime).toLocaleTimeString("en-LK", { timeZone: TZ });
      }
      return txt;
    }
    if (start.date) return new Date(start.date).toLocaleDateString("en-LK");
    return "";
  }

  function sameMonth(a, b) {
    return a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth();
  }

  function sameDay(a, b) {
    return (
      a.getFullYear() === b.getFullYear() &&
      a.getMonth()    === b.getMonth()    &&
      a.getDate()     === b.getDate()
    );
  }

  /** Treat common calendar placeholders as empty (never show literal N/A). */
  function sanitizeDetailField(v) {
    if (v == null) return "";
    var t = String(v).trim();
    if (!t) return "";
    if (/^n\/?a\.?$/i.test(t)) return "";
    if (/^not applicable$/i.test(t)) return "";
    if (/^-\s*$/.test(t)) return "";
    if (/^—$/.test(t)) return "";
    if (typeof window.edmStripVisibleUrls === "function") {
      t = window.edmStripVisibleUrls(t);
    }
    return t;
  }

  /** Single newlines → space; keep paragraph breaks for value boundaries. */
  function normalizeDescriptionForLabels(rawHtml) {
    var s = String(rawHtml || "")
      .replace(/<[^>]+>/g, "\n")
      .replace(/&nbsp;/g, " ")
      .replace(/\r\n?/g, "\n");
    s = s.replace(/[ \t]+\n/g, "\n").replace(/\n[ \t]+/g, "\n");
    s = s.replace(/([^\n])\n(?!\n)/g, "$1 ");
    return s.replace(/\n{3,}/g, "\n\n").trim();
  }

  /** First occurrence of each EDM template label on a single-line string. */
  function edmLabelFirstHits(flat) {
    var labelSpecs = [
      { key: "organiser", re: /Organiser\s*:/gi },
      { key: "contact", re: /Contact\s+Person\s*:/gi },
      { key: "phone1", re: /Phone\s*1\s*:/gi },
      { key: "phone2", re: /Phone\s*2\s*:/gi },
      { key: "artists", re: /(?:🎧\s*)?Artists\s+Lineup\s*:/gi },
      { key: "notes", re: /(?:📝\s*)?Notes\s*:/gi },
      { key: "_img", re: /(?:Poster\s*(?:URL|Image)|Image\s+URL|Event\s+image|Flyer\s+URL)\s*:/gi },
      { key: "_book", re: /(?:Book(?:ing)?\s+URL|Book\s+now\s+link)\s*:/gi },
    ];
    var hits = [];
    labelSpecs.forEach(function (spec) {
      spec.re.lastIndex = 0;
      var m = spec.re.exec(flat);
      if (m)
        hits.push({
          key: spec.key,
          labelStart: m.index,
          valueStart: m.index + m[0].length,
        });
    });
    hits.sort(function (a, b) {
      return a.labelStart - b.labelStart;
    });
    var seen = {};
    return hits
      .filter(function (h) {
        if (seen[h.key]) return false;
        seen[h.key] = true;
        return true;
      })
      .sort(function (a, b) {
        return a.labelStart - b.labelStart;
      });
  }

  /**
   * Parse EDM organiser template (single-line or multi-line). Uses label
   * boundaries so values do not swallow the next field (greedy [^\n]+ bug).
   */
  function parseDescription(raw) {
    var empty = {
      organiser: "",
      contact: "",
      phone1: "",
      phone2: "",
      artists: "",
      notes: "",
      type: "",
    };
    if (!raw) return empty;

    var clean = normalizeDescriptionForLabels(raw);
    clean = clean.replace(/🎉\s*EDM\s+EVENT\s+DETAILS\s*🎉/gi, " ").trim();
    clean = clean.replace(/\s+/g, " ").trim();

    var hits = edmLabelFirstHits(clean);

    var out = {
      organiser: "",
      contact: "",
      phone1: "",
      phone2: "",
      artists: "",
      notes: "",
      type: "",
    };

    for (var i = 0; i < hits.length; i++) {
      var key = hits[i].key;
      if (key.charAt(0) === "_") continue;
      var end = i + 1 < hits.length ? hits[i + 1].labelStart : clean.length;
      var rawVal = clean.slice(hits[i].valueStart, end).trim();
      out[key] = sanitizeDetailField(rawVal);
    }

    if (hits.length >= 1) out.type = "EDM Event";
    else if (/EDM/i.test(clean)) out.type = "EDM Event";

    return out;
  }

  /** Remove EDM metadata template from plain description so lede is real copy. */
  function stripEdmMetadataFromPlain(plain) {
    if (!plain) return plain;
    var flat = normalizeDescriptionForLabels(plain).replace(/\s+/g, " ").trim();
    var hits = edmLabelFirstHits(flat);
    var hM = flat.match(/🎉\s*EDM\s+EVENT\s+DETAILS\s*🎉/i);

    if (!hits.length) {
      if (hM)
        return (
          flat.slice(0, hM.index) + " " + flat.slice(hM.index + hM[0].length)
        )
          .replace(/\s+/g, " ")
          .trim();
      return plain;
    }

    var blockStart = hits[0].labelStart;
    if (hM && hM.index < blockStart) blockStart = hM.index;

    var last = hits[hits.length - 1];
    var blockEnd = flat.length;
    var httpAt = flat.indexOf("http", last.valueStart);
    if (httpAt > last.valueStart) blockEnd = httpAt;

    var out = (flat.slice(0, blockStart) + " " + flat.slice(blockEnd))
      .replace(/\s+/g, " ")
      .trim();
    return out || "";
  }

  var STORAGE_DETAIL_KEY = "edm:eventDetail";
  var DETAILS_PAGE = "event-details.html";

  function escapeHtmlAttr(s) {
    return String(s == null ? "" : s)
      .replace(/&/g, "&amp;")
      .replace(/"/g, "&quot;")
      .replace(/</g, "&lt;")
      .replace(/\n/g, " ");
  }

  function safeHttpUrl(url) {
    if (!url || typeof url !== "string") return "";
    var t = url.trim();
    if (!/^https:\/\//i.test(t) && !/^http:\/\//i.test(t)) return "";
    return t.replace(/[\s"'<>]/g, "");
  }

  /** http(s) or same-site path (e.g. /tickets.html) for Book now targets */
  function safeNavigationUrl(url) {
    if (!url || typeof url !== "string") return "";
    var t = url.trim();
    if (/^https:\/\//i.test(t) || /^http:\/\//i.test(t))
      return t.replace(/[\s"'<>]/g, "");
    if (t.indexOf("/") === 0 && t.indexOf("//") !== 0)
      return t.replace(/[\s"'<>]/g, "");
    return "";
  }

  var BOOK_URL_LINE_RE =
    /(?:^|\n)[ \t]*(?:🎫[ \t]*)?(?:Book(?:ing)?[ \t]+URL|Book[ \t]+now[ \t]*link)\s*:\s*(https?:\/\/[^\s<>'"]+)/gi;

  function extractBookUrlFromDescription(rawHtml) {
    if (!rawHtml) return "";
    var plain = String(rawHtml).replace(/<[^>]+>/g, "\n");
    BOOK_URL_LINE_RE.lastIndex = 0;
    var m = BOOK_URL_LINE_RE.exec(plain);
    return m ? safeNavigationUrl(m[1]) : "";
  }

  function stripBookUrlLabelLines(plain) {
    if (!plain) return plain;
    return plain
      .replace(BOOK_URL_LINE_RE, "\n")
      .replace(/\n{3,}/g, "\n\n")
      .trim();
  }

  function getEventBookUrl(item) {
    if (!item) return "";
    var direct = safeNavigationUrl(item.bookUrl || "");
    if (direct) return direct;
    return extractBookUrlFromDescription(item.description || "");
  }

  /** Max edge for Drive thumbnail embed (w or h); keeps posters sharp on retina. */
  var DRIVE_THUMB_SZ = 1200;

  /**
   * Convert common Google Drive sharing links to a URL that works in <img src>.
   * Uses the thumbnail endpoint — uc?export=view often returns an HTML interstitial
   * for large images instead of raw bytes.
   * The file (or a parent folder policy) must allow access without Google sign-in
   * ("Anyone with the link" as Viewer; avoid link sharing that says sign-in required).
   */
  function googleDriveShareToDirectView(url) {
    if (!url || typeof url !== "string") return "";
    var t = url.trim().split(/[\s"'<>]/)[0];
    var m = t.match(/https?:\/\/drive\.google\.com\/file\/d\/([a-zA-Z0-9_-]+)/i);
    if (m)
      return (
        "https://drive.google.com/thumbnail?id=" +
        m[1] +
        "&sz=w" +
        DRIVE_THUMB_SZ
      );
    m = t.match(/https?:\/\/drive\.google\.com\/open\?id=([a-zA-Z0-9_-]+)/i);
    if (m)
      return (
        "https://drive.google.com/thumbnail?id=" +
        m[1] +
        "&sz=w" +
        DRIVE_THUMB_SZ
      );
    if (/drive\.google\.com\/thumbnail/i.test(t)) {
      m = t.match(/[?&]id=([a-zA-Z0-9_-]+)/i);
      if (m)
        return (
          "https://drive.google.com/thumbnail?id=" +
          m[1] +
          "&sz=w" +
          DRIVE_THUMB_SZ
        );
    }
    if (/drive\.google\.com\/uc\?/i.test(t)) {
      m = t.match(/[?&]id=([a-zA-Z0-9_-]+)/i);
      if (m)
        return (
          "https://drive.google.com/thumbnail?id=" +
          m[1] +
          "&sz=w" +
          DRIVE_THUMB_SZ
        );
    }
    return "";
  }

  function extractGoogleDriveImageFromText(plain) {
    if (!plain) return "";
    var s = String(plain);
    var m;
    var reFile = /https?:\/\/drive\.google\.com\/file\/d\/[a-zA-Z0-9_-]+/gi;
    while ((m = reFile.exec(s))) {
      var d = googleDriveShareToDirectView(m[0]);
      if (d) return d;
    }
    var reOpen = /https?:\/\/drive\.google\.com\/open\?id=[a-zA-Z0-9_-]+/gi;
    while ((m = reOpen.exec(s))) {
      var d2 = googleDriveShareToDirectView(m[0]);
      if (d2) return d2;
    }
    var reUc = /https?:\/\/drive\.google\.com\/uc\?[^\s"'<>]+/gi;
    while ((m = reUc.exec(s))) {
      var d3 = googleDriveShareToDirectView(m[0]);
      if (d3) return d3;
    }
    return "";
  }

  /** URL safe for <img src> (Drive share links → thumbnail endpoint). */
  function imgSrcForCard(url) {
    if (!url) return "";
    var t = String(url).trim();
    var s = safeHttpUrl(t) || (t.indexOf("/") === 0 ? t.replace(/[\s"'<>]/g, "") : "");
    if (!s) return "";
    var d = googleDriveShareToDirectView(s);
    return d || s;
  }

  function extractImageUrl(raw, item) {
    var direct = item && item.imageUrl ? imgSrcForCard(item.imageUrl) : "";
    if (direct) return direct;
    if (!raw) return "";
    var plain = String(raw).replace(/<[^>]+>/g, " ");

    var fromDrive = extractGoogleDriveImageFromText(plain);
    if (fromDrive) return safeHttpUrl(fromDrive);

    var gc = plain.match(
      /https?:\/\/lh\d\.googleusercontent\.com\/[^\s"'<>)]+/i
    );
    if (gc) return safeHttpUrl(gc[0]);

    var m = plain.match(
      /https?:\/\/[^\s"'<>]+\.(?:jpg|jpeg|png|webp|gif)(?:\?[^\s"'<>]*)?/i
    );
    return m ? safeHttpUrl(m[0]) : "";
  }

  function normalizeText(s) {
    return String(s || "")
      .toLowerCase()
      .replace(/&/g, " and ")
      .replace(/[^a-z0-9\s]/g, " ")
      .replace(/\s+/g, " ")
      .trim();
  }

  function hashIndexFromText(text, size) {
    var s = String(text || "");
    var h = 0;
    for (var i = 0; i < s.length; i++) {
      h = ((h << 5) - h + s.charCodeAt(i)) >>> 0;
    }
    if (!size) return 0;
    return h % size;
  }

  function uniqueCardImage(item, idx) {
    var title = item && item.summary ? item.summary : "event";
    var loc = item && item.location ? item.location : "sri-lanka";
    var start = getStartDate(item);
    var day = start
      ? start.toISOString().slice(0, 10)
      : "na-date";
    var safeIdx = typeof idx === "number" && idx >= 0 ? idx : 0;
    var seed = normalizeText(title + "-" + loc + "-" + day + "-" + safeIdx).replace(/\s+/g, "-");
    var pool = (window.EVENT_LOCAL_IMAGES && Array.isArray(window.EVENT_LOCAL_IMAGES) && window.EVENT_LOCAL_IMAGES.length)
      ? window.EVENT_LOCAL_IMAGES
      : LOCAL_EVENT_IMAGES;
    if (!pool || !pool.length) return "";
    var pick = hashIndexFromText(seed, pool.length);
    return pool[pick];
  }

  function safePosterSrc(url) {
    if (!url || typeof url !== "string") return "";
    var t = url.trim();
    if (!t) return "";
    if (/^https?:\/\//i.test(t)) return safeHttpUrl(t);
    if (/^javascript:/i.test(t) || /^data:/i.test(t)) return "";
    return t.replace(/["<>]/g, "");
  }

  function posterMapSlug(summary) {
    return normalizeText(summary || "")
      .replace(/\s+/g, "-")
      .replace(/-+/g, "-")
      .replace(/^-|-$/g, "");
  }

  function extractPosterLabelUrl(raw) {
    if (!raw) return "";
    var plain = String(raw).replace(/<[^>]+>/g, "\n");
    var m = plain.match(
      /(?:^|\n)\s*(?:Poster\s*(?:URL|Image)\s*:|Event\s+image\s*:|Image\s+URL\s*:|Flyer\s+URL\s*:)\s*(\S+)/im
    );
    if (!m) return "";
    var u = safePosterSrc(m[1]);
    if (!u) return "";
    var drive = googleDriveShareToDirectView(u);
    return drive || u;
  }

  /**
   * Poster for grid cards / detail: EVENT_POSTER_MAP (by event id, title, or slug),
   * description line "Poster URL:", first image URL in description, Google image,
   * then local pool.
   */
  function resolveEventPosterUrl(item, idx) {
    var map = window.EVENT_POSTER_MAP || {};
    if (item && item.id) {
      var idKey = "id:" + String(item.id);
      if (map[idKey]) {
        var byId = safePosterSrc(map[idKey]);
        if (byId) return byId;
      }
    }
    var sum = item && item.summary ? String(item.summary).trim() : "";
    if (sum && map[sum]) {
      var bySum = safePosterSrc(map[sum]);
      if (bySum) return bySum;
    }
    var slug = posterMapSlug(sum);
    if (slug && map[slug]) {
      var bySlug = safePosterSrc(map[slug]);
      if (bySlug) return bySlug;
    }
    var fromLabel = extractPosterLabelUrl(item && item.description ? item.description : "");
    if (fromLabel) return fromLabel;
    var fromDesc = extractImageUrl(item && item.description ? item.description : "", item || {});
    if (fromDesc) return fromDesc;
    var realIdx = typeof idx === "number" && idx >= 0 ? idx : eventRealIndex(item);
    return uniqueCardImage(item, realIdx);
  }

  function minLkrNumber(desc, summary) {
    var text = (desc || "") + " " + (summary || "");
    var re = /LKR\s*([\d,]+)/gi;
    var m;
    var nums = [];
    while ((m = re.exec(text))) {
      nums.push(parseInt(m[1].replace(/,/g, ""), 10));
    }
    if (!nums.length) return null;
    return Math.min.apply(null, nums);
  }

  function extractPriceDisplay(desc, summary) {
    var n = minLkrNumber(desc, summary);
    if (n == null) return "—";
    return "LKR " + n.toLocaleString("en-LK");
  }

  function extractTrailerUrl(raw) {
    if (!raw) return "";
    var y = raw.match(
      /https?:\/\/(?:www\.)?(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{6,})/i
    );
    if (y) return y[0].split("&")[0];
    var v = raw.match(/https?:\/\/vimeo\.com\/\d+/i);
    return v ? v[0] : "";
  }

  function parseTicketTiers(raw, floorPrice) {
    var clean = (raw || "").replace(/<[^>]+>/g, "\n");
    var lines = clean.split(/\n/);
    var tiers = [];
    var rLine = /^(.+?)[\s\-–—:]+LKR\s*([\d,]+)/i;
    for (var i = 0; i < lines.length; i++) {
      var line = lines[i].trim();
      if (!line) continue;
      var m = line.match(rLine);
      if (!m) continue;
      var name = m[1].replace(/^[\s*•\-]+/, "").trim();
      if (name.length < 2 || name.length > 52) continue;
      var price = parseInt(m[2].replace(/,/g, ""), 10);
      if (!isFinite(price)) continue;
      var sold = /sold\s*out|soldout|SOLD\s*OUT/i.test(line);
      tiers.push({
        name: name,
        price: price,
        soldOut: sold,
        subtitle: "Standing event",
      });
    }
    if (!tiers.length && floorPrice != null) {
      tiers.push({
        name: "General admission",
        price: floorPrice,
        soldOut: false,
        subtitle: "Standing event",
      });
    }
    if (!tiers.length) {
      tiers.push({
        name: "General admission",
        price: null,
        soldOut: false,
        subtitle: "Standing event",
      });
    }
    return tiers;
  }

  function gradientCssForTitle(t) {
    var s = String(t || "Event");
    var h = 0;
    for (var i = 0; i < s.length; i++) {
      h = ((h << 5) - h + s.charCodeAt(i)) >>> 0;
    }
    var h1 = h % 360;
    var h2 = (h1 + 48) % 360;
    return (
      "linear-gradient(138deg,hsl(" +
      h1 +
      ",78%,42%) 0%,hsl(" +
      h2 +
      ",70%,14%) 100%)"
    );
  }

  function formatCardTimeLine(item) {
    var s = item.start || {};
    if (s.dateTime) {
      var a = new Date(s.dateTime);
      var t = a.toLocaleTimeString("en-LK", {
        timeZone: TZ,
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
      });
      var end = item.end && item.end.dateTime ? new Date(item.end.dateTime) : null;
      if (
        end &&
        a.toDateString() === end.toDateString()
      ) {
        var et = end.toLocaleTimeString("en-LK", {
          timeZone: TZ,
          hour: "numeric",
          minute: "2-digit",
          hour12: true,
        });
        return t + " – " + et;
      }
      return t + " onwards";
    }
    if (s.date) return "All day event";
    return "Time TBA";
  }

  function buildDetailPayload(item, idxOpt) {
    var start = getStartDate(item);
    var end = getEndDate(item);
    var descPlain = (item.description || "")
      .replace(/<[^>]+>/g, "\n")
      .replace(/[ \t]+\n/g, "\n")
      .replace(/\n{3,}/g, "\n\n")
      .trim();
    descPlain = descPlain.replace(/\bN\/?A\b/gi, "").replace(/\n{3,}/g, "\n\n").trim();
    descPlain = stripEdmMetadataFromPlain(descPlain);
    descPlain = stripBookUrlLabelLines(descPlain);
    if (typeof window.edmStripVisibleUrls === "function") {
      descPlain = window.edmStripVisibleUrls(descPlain);
    }
    descPlain = descPlain.slice(0, 12000);
    var d = parseDescription(item.description || "");
    var floor = minLkrNumber(item.description || "", item.summary || "");
    var tiers = parseTicketTiers(item.description || "", floor);
    var realIdx =
      typeof idxOpt === "number" && idxOpt >= 0
        ? idxOpt
        : eventRealIndex(item);
    if (realIdx < 0) realIdx = 0;
    var img = resolveEventPosterUrl(item, realIdx);
    var trailer = extractTrailerUrl(item.description || "");
    var loc = sanitizeDetailField(item.location || "");
    var needle = loc + " " + descPlain;
    var venueBadge = "";
    if (/outdoor|open\s*-?\s*air|beach|rooftop|garden\s*stage/i.test(needle))
      venueBadge = "OUTDOOR";

    var dateLong = start
      ? start.toLocaleDateString("en-LK", {
          timeZone: TZ,
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      : "";
    var timeLine = formatCardTimeLine(item);
    var dateLine = (dateLong ? dateLong + " · " : "") + timeLine;

    return {
      v: 1,
      summary: sanitizeDetailField(item.summary) || "Event",
      descriptionPlain: descPlain,
      location: loc,
      organiser: sanitizeDetailField(d.organiser),
      contact: sanitizeDetailField(d.contact),
      phone1: sanitizeDetailField(d.phone1),
      phone2: sanitizeDetailField(d.phone2),
      artists: sanitizeDetailField(d.artists),
      notes: sanitizeDetailField(d.notes),
      startMs: start ? start.getTime() : null,
      startISO: start ? start.toISOString() : "",
      endISO: end ? end.toISOString() : "",
      dateLong: dateLong,
      timeLine: timeLine,
      dateLine: dateLine,
      imageUrl: img,
      posterFallbackBg: gradientCssForTitle(item.summary || ""),
      trailerUrl: trailer,
      showTrailer: !!trailer,
      tiers: tiers,
      priceFloor: floor,
      venueBadge: venueBadge,
      eventEnded: start ? start < new Date() : false,
      htmlLink: item.htmlLink || "",
      bookUrl: getEventBookUrl(item),
    };
  }

  function handleBookNowClick(item, idx) {
    if (!item) return;
    var book = getEventBookUrl(item);
    if (book) {
      if (/^https?:\/\//i.test(book)) {
        window.open(book, "_blank", "noopener,noreferrer");
      } else {
        window.location.assign(book);
      }
      return;
    }
    var openIdx = typeof idx === "number" && idx >= 0 ? idx : eventRealIndex(item);
    if (openIdx < 0) return;
    openEventDetailsForIndex(openIdx);
  }

  function openEventDetailsForIndex(idx) {
    var item = findEventAtIndex(idx);
    if (!item) return;
    try {
      sessionStorage.setItem(
        STORAGE_DETAIL_KEY,
        JSON.stringify(buildDetailPayload(item, idx))
      );
    } catch (err) {
      return;
    }
    window.location.assign(DETAILS_PAGE);
  }

  function eventThumbCard(item, idx) {
    var realIdx =
      typeof idx === "number" && idx >= 0 ? idx : eventRealIndex(item);
    var start = getStartDate(item);
    var now = new Date();
    var isPast = start && start < now;
    var title = sanitizeDetailField(item.summary) || "Event";
    var locSl = sanitizeDetailField(item.location || "");
    var loc = locSl || "Venue TBA";
    var monthAbbr = "";
    var dayNum = "—";
    if (start) {
      monthAbbr = start.toLocaleDateString("en-LK", {
        timeZone: TZ,
        month: "short",
      });
      dayNum = start.toLocaleDateString("en-LK", {
        timeZone: TZ,
        day: "numeric",
      });
    }
    var timeLine = formatCardTimeLine(item);
    var imgUrl = resolveEventPosterUrl(item, realIdx);
    var grad = gradientCssForTitle(title);
    var posterBgStyle =
      "background:" +
      grad +
      ";background-size:cover;background-position:center;";
    var posterInner = imgUrl
      ? '<img class="edc-poster-img" src="' +
        escapeHtmlAttr(imgUrl) +
        '" alt="' +
        escapeHtmlAttr(title) +
        '" loading="lazy" decoding="async" onerror="this.style.display=\'none\'">'
      : "";

    var statusBadgeHtml = isPast
      ? '<span class="edc-badge-expired" aria-hidden="true">Expired</span>'
      : '<span class="edc-badge-featured" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7L12 16.3 5.7 21l2.3-7-6-4.6h7.6z"/></svg>Featured</span>';

    var btnLabel = isPast ? "Expired" : "Book now";

    return (
      '<article class="edc-card edc-reveal-ready' +
      (isPast ? " edc-card--past" : "") +
      '">' +
      '<div class="edc-card-poster" style="' +
      escapeHtmlAttr(posterBgStyle) +
      '">' +
      statusBadgeHtml +
      '<div class="edc-date-corner"><span class="edc-date-corner-month">' +
      escapeHtml(monthAbbr) +
      '</span><span class="edc-date-corner-day">' +
      escapeHtml(String(dayNum)) +
      "</span></div>" +
      posterInner +
      "</div>" +
      '<div class="edc-card-body">' +
      '<p class="edc-card-time">' +
      escapeHtml(timeLine) +
      "</p>" +
      '<div class="edc-card-title-row">' +
      '<h3 class="edc-card-title">' +
      escapeHtml(title) +
      "</h3>" +
      '<button type="button" class="edc-book-btn edc-book-btn--square"' +
      (realIdx >= 0 ? ' data-idx="' + realIdx + '"' : "") +
      (item.id ? ' data-event-id="' + escapeHtmlAttr(String(item.id)) + '"' : "") +
      (isPast ? " disabled aria-disabled=\"true\"" : "") +
      ' aria-label="' +
      escapeHtmlAttr(btnLabel) +
      '">' +
      '<span class="edc-book-btn__stack" aria-hidden="true">' +
      '<span class="edc-book-btn__line">Book</span>' +
      '<span class="edc-book-btn__line">now</span>' +
      "</span>" +
      "</button>" +
      "</div>" +
      '<p class="edc-card-venue">' +
      escapeHtml(loc) +
      "</p>" +
      "</div></article>"
    );
  }

  /* ── Single detail row ── */
  function detailRow(icon, label, value) {
    var v = sanitizeDetailField(value);
    if (!v) return "";
    return `
      <div class="card-detail">
        <span class="card-detail-icon">${icon}</span>
        <strong>${label}</strong>
        <span>${escapeHtml(v)}</span>
      </div>`;
  }

  /* ── Countdown helpers ── */
  function pad2(n) {
    return String(Math.max(0, n)).padStart(2, "0");
  }

  function countdownHtml(item, idx) {
    var target = getStartDate(item);
    if (!target) return "";
    var diff = target - new Date();
    if (diff <= 0) return '<p class="cd-past">This event has ended.</p>';
    var d = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000)  / 60000);
    var s = Math.floor((diff % 60000)    / 1000);
    return `
      <div class="cd-label-row"><span class="cd-live-dot"></span>Countdown to event</div>
      <div class="card-countdown">
        <div class="cd-unit"><span class="cd-num" id="cd-d-${idx}">${pad2(d)}</span><span class="cd-lbl">Days</span></div>
        <div class="cd-unit"><span class="cd-num" id="cd-h-${idx}">${pad2(h)}</span><span class="cd-lbl">Hrs</span></div>
        <div class="cd-unit"><span class="cd-num" id="cd-m-${idx}">${pad2(m)}</span><span class="cd-lbl">Min</span></div>
        <div class="cd-unit"><span class="cd-num" id="cd-s-${idx}">${pad2(s)}</span><span class="cd-lbl">Sec</span></div>
      </div>`;
  }

  /* ── Format date to iCal / Google Calendar string ── */
  function toCalDate(date) {
    if (!date) return "";
    return date.toISOString().replace(/[-:]/g, "").split(".")[0] + "Z";
  }

  /* ── WhatsApp share text ── */
  function buildWhatsAppUrl(item) {
    var title   = item.summary  || "Event";
    var loc     = item.location || "";
    var when    = formatEventRange(item);
    var pageUrl = window.location.href.split("?")[0];
    var text = "\uD83C\uDFB5 *" + title + "*";
    if (when) text += "\n\uD83D\uDCC5 " + when;
    if (loc)  text += "\n\uD83D\uDCCD " + loc;
    text += "\n\n\uD83D\uDC49 " + pageUrl;
    return "https://wa.me/?text=" + encodeURIComponent(text);
  }

  /* ── Google Calendar URL ── */
  function buildGoogleCalUrl(item) {
    var title = item.summary  || "Event";
    var loc   = item.location || "";
    var desc  = item.description ? item.description.replace(/<[^>]+>/g, " ").trim() : "";
    var start = toCalDate(getStartDate(item));
    var end   = toCalDate(getEndDate(item));
    return "https://calendar.google.com/calendar/render?action=TEMPLATE" +
      "&text="     + encodeURIComponent(title) +
      "&dates="    + start + "/" + end +
      "&location=" + encodeURIComponent(loc) +
      "&details="  + encodeURIComponent(desc);
  }

  /* ── Apple / iCal .ics download ── */
  function buildIcsContent(item) {
    var title = item.summary  || "Event";
    var loc   = item.location || "";
    var desc  = item.description ? item.description.replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim() : "";
    var start = toCalDate(getStartDate(item));
    var end   = toCalDate(getEndDate(item));
    var now   = toCalDate(new Date());
    var uid   = now + "-" + Math.random().toString(36).substr(2, 9) + "@edmcalendar.lk";
    return [
      "BEGIN:VCALENDAR",
      "VERSION:2.0",
      "PRODID:-//edmcalendar.lk//EN",
      "BEGIN:VEVENT",
      "UID:"         + uid,
      "DTSTAMP:"     + now,
      "DTSTART:"     + start,
      "DTEND:"       + end,
      "SUMMARY:"     + title,
      "LOCATION:"    + loc,
      "DESCRIPTION:" + desc,
      "END:VEVENT",
      "END:VCALENDAR"
    ].join("\r\n");
  }

  function downloadIcs(item) {
    var content  = buildIcsContent(item);
    var blob     = new Blob([content], { type: "text/calendar;charset=utf-8" });
    var url      = URL.createObjectURL(blob);
    var a        = document.createElement("a");
    var filename = (item.summary || "event").replace(/[^a-z0-9]/gi, "_").toLowerCase() + ".ics";
    a.href       = url;
    a.download   = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  /* ── Action buttons HTML ── */
  function actionButtonsHtml(idx) {
    return `
      <div class="card-actions">
        <a class="card-action-btn wa-btn" href="#" data-idx="${idx}" title="Share on WhatsApp">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.534 5.855L.057 23.882a.5.5 0 0 0 .612.612l6.098-1.469A11.946 11.946 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.667-.5-5.203-1.377l-.374-.214-3.878.934.951-3.793-.228-.374A9.944 9.944 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          Share
        </a>
        <div class="cal-add-wrap">
          <button class="card-action-btn cal-btn-trigger" data-idx="${idx}" title="Add to Calendar">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8"  y1="2" x2="8"  y2="6"></line>
              <line x1="3"  y1="10" x2="21" y2="10"></line>
              <line x1="12" y1="14" x2="12" y2="18"></line>
              <line x1="10" y1="16" x2="14" y2="16"></line>
            </svg>
            Add to Calendar
          </button>
          <div class="cal-dropdown" id="cal-drop-${idx}">
            <a href="#" class="cal-drop-item google-cal" data-idx="${idx}">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0">
                <path d="M21.35 11.1h-9.17v2.73h6.51c-.33 3.81-3.5 5.44-6.5 5.44C8.36 19.27 5 16.25 5 12c0-4.1 3.2-7.27 7.2-7.27 3.09 0 4.9 1.97 4.9 1.97L19 4.72S16.56 2 12.1 2C6.42 2 2.03 6.8 2.03 12c0 5.05 4.13 10 10.22 10 5.35 0 9.25-3.67 9.25-9.09 0-1.15-.15-1.81-.15-1.81z"/>
              </svg>
              Google Calendar
            </a>
            <a href="#" class="cal-drop-item apple-cal" data-idx="${idx}">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              Apple Calendar
            </a>
          </div>
        </div>
      </div>`;
  }

  /* ── Event card (calendar section) ── */
  function eventCard(item, idx) {
    var title     = item.summary  || "No Title";
    var when      = formatEventRange(item);
    var loc       = item.location || "";
    var now       = new Date();
    var eventDate = getStartDate(item);
    var isPast    = eventDate && eventDate < now;

    var badgeClass = isPast ? "closed"    : "available";
    var badgeText  = isPast ? "Closed"    : "Available";

    var d    = parseDescription(item.description || "");
    var tags = d.type
      ? `<div class="card-tags"><span class="card-tag edm">${escapeHtml(d.type)}</span></div>`
      : "";

    return `
      <div class="calendar-card">
        <div class="card-header">
          <h4>${escapeHtml(title)}</h4>
          <span class="event-badge ${badgeClass}">${badgeText}</span>
        </div>
        <hr class="card-divider">
        <div class="calendar-card-main">
        ${detailRow("📅", "Date",      when)}
        ${detailRow("📍", "Venue",     loc)}
        ${detailRow("👤", "Organiser", d.organiser)}
        ${detailRow("👤", "Contact",   d.contact)}
        ${detailRow("📞", "Phone 1",   d.phone1)}
        ${detailRow("📞", "Phone 2",   d.phone2)}
        ${detailRow("🎧", "Artists",   d.artists)}
        ${detailRow("📝", "Notes",     d.notes)}
        ${tags}
        ${countdownHtml(item, idx)}
        </div>
        ${!isPast ? actionButtonsHtml(idx) : ""}
      </div>`;
  }

  /* ── Render calendar section ── */
  function renderEvents() {
    var $root = $eventsRoot;
    if (!$root || !$root.length) return;

    var view = state.view;
    var allFetched = state.events || [];
    var html       = "";
    var toolbarTitle = "";

    if (!allFetched.length) {
      $root.html('<p class="calendar-events-msg">No events found.</p>');
      return;
    }

    var filtered = getFilteredEvents();
    var filtersOn = anyFilterActive();

    /* DAY VIEW */
    if (view === "day") {
      var dayItems = filtersOn
        ? filtered.slice().sort(sortByStartDate)
        : filtered.filter(function (item) {
            var d = getStartDate(item);
            return d && sameDay(d, state.cursor);
          });

      var dayTitle = filtersOn
        ? (dayItems.length === 1 ? "1 matching event" : dayItems.length + " matching events")
        : state.cursor.toLocaleDateString("en-LK", {
            timeZone: TZ, weekday: "long", year: "numeric",
            month: "long", day: "numeric",
          });

      html += '<div class="edc-events-grid">';
      if (!dayItems.length) {
        html += `<div class="edc-empty-tile calendar-empty-msg">${
          filtersOn ? "No events match your filters." : "No events scheduled for this day."
        }</div>`;
      } else {
        if (!filtersOn) dayItems.sort(sortByStartDate);
        dayItems.forEach(function (item) { html += eventThumbCard(item, eventRealIndex(item)); });
      }
      html += "</div>";
      toolbarTitle = dayTitle;
    }

    /* YEAR VIEW */
    else if (view === "year") {
      var year       = state.cursor.getFullYear();
      var monthCount = {};

      filtered.forEach(function (item) {
        var d = getStartDate(item);
        if (!d || d.getFullYear() !== year) return;
        var k = d.getMonth();
        monthCount[k] = (monthCount[k] || 0) + 1;
      });

      var maxCount = 1;
      for (var k in monthCount) {
        if (monthCount[k] > maxCount) maxCount = monthCount[k];
      }

      function bubbleClass(c) {
        if (c === 0) return "zero";
        if (c <= 2)  return "low";
        if (c <= 7)  return "mid";
        return "high";
      }

      function makeDots(count) {
        if (!count) return "";
        var n    = Math.min(count, 12);
        var dots = "";
        for (var x = 0; x < n; x++) {
          dots += '<div class="month-dot' + (x % 3 === 2 ? " gold" : "") + '"></div>';
        }
        return '<div class="month-dots">' + dots + "</div>";
      }

      html += '<div class="year-grid">';
      for (var i = 0; i < 12; i++) {
        var monthName = new Date(year, i, 1).toLocaleDateString("en-LK", { month: "short" });
        var count  = monthCount[i] || 0;
        var has    = count > 0;
        var pct    = Math.round((count / maxCount) * 100);
        var label  = count === 1 ? "1 event" : count + " events";

        html += `
          <div class="month-card${has ? " has-events" : ""} month-click" data-month="${i}">
            <div class="month-name-row">
              <span class="month-name">${monthName}</span>
              <div class="month-count-bubble ${bubbleClass(count)}">${count}</div>
            </div>
            <hr class="month-divider">
            <span class="month-event-label">${label}</span>
            <div class="month-bar-track">
              <div class="month-bar-fill" style="width:${pct}%"></div>
            </div>
            ${has ? makeDots(count) : ""}
          </div>`;
      }
      html += "</div>";
      toolbarTitle = String(year);
    }

    /* MONTH VIEW — with hero filters on, list all matches (not only cursor month) */
    else {
      var monthItems = filtersOn
        ? filtered.slice().sort(sortByStartDate)
        : filtered.filter(function (item) {
            var d = getStartDate(item);
            return d && sameMonth(d, state.cursor);
          });

      var monthTitle = filtersOn
        ? (monthItems.length === 1 ? "1 matching event" : monthItems.length + " matching events")
        : state.cursor.toLocaleDateString("en-LK", {
            month: "long", year: "numeric",
          });

      html += '<div class="edc-events-grid edc-calendar-wrap">';
      if (!monthItems.length) {
        html += `<div class="edc-empty-tile calendar-empty-msg">${
          filtersOn ? "No events match your filters." : "No events scheduled this month."
        }</div>`;
      } else {
        if (!filtersOn) monthItems.sort(sortByStartDate);
        monthItems.forEach(function (item) { html += eventThumbCard(item, eventRealIndex(item)); });
      }
      html += "</div>";
      toolbarTitle = monthTitle;
    }

    $root.html(html);
    syncToolbarUI(toolbarTitle);
    updateFilterLiveStatus();
    observeEventCardReveals($root[0] || $root);
  }

  var cardRevealIo = null;
  function observeEventCardReveals(rootEl) {
    if (!rootEl || typeof IntersectionObserver === "undefined") {
      (rootEl || document).querySelectorAll(".edc-reveal-ready").forEach(function (c) {
        c.classList.add("is-visible");
      });
      return;
    }
    var reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    var cards = rootEl.querySelectorAll(".edc-reveal-ready:not(.is-visible)");
    if (reduced) {
      cards.forEach(function (c) {
        c.classList.add("is-visible");
      });
      return;
    }
    if (!cardRevealIo) {
      cardRevealIo = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            entry.target.classList.add("is-visible");
            cardRevealIo.unobserve(entry.target);
          });
        },
        { threshold: 0.12, rootMargin: "0px 0px -4% 0px" }
      );
    }
    cards.forEach(function (card, i) {
      card.style.transitionDelay = Math.min(i * 0.04, 0.32) + "s";
      cardRevealIo.observe(card);
    });
  }

  /* ── Controls ── */
  function attachCalendarControls() {
    calendarShells.forEach(function (entry) {
      var $shell = entry.$shell;
      if (!$shell || !$shell.length) return;

      $shell.find(".calendar-view-switch .cal-btn").on("click", function () {
        setView($(this).data("view"), $shell.hasClass("calendar-shell--nav-only"));
      });

      $shell.find(".calendar-nav-btn").first().on("click", function () {
        if ((state.view === "month" || state.view === "day") && anyFilterActive()) return;
        stepCursor(state.view, "prev");
        renderEvents();
        if ($shell.hasClass("calendar-shell--nav-only")) scrollToEventsContent();
      });

      $shell.find(".calendar-nav-btn").last().on("click", function () {
        if ((state.view === "month" || state.view === "day") && anyFilterActive()) return;
        stepCursor(state.view, "next");
        renderEvents();
        if ($shell.hasClass("calendar-shell--nav-only")) scrollToEventsContent();
      });
    });

    $(document).on("click", ".month-click", function () {
      var month = parseInt($(this).data("month"), 10);
      state.cursor.setMonth(month);
      setView("month");
    });

    /* ── WhatsApp share ── */
    $(document).on("click", ".wa-btn", function (e) {
      e.preventDefault();
      var idx  = parseInt($(this).data("idx"), 10);
      var item = findEventAtIndex(idx);
      if (!item) return;
      window.open(buildWhatsAppUrl(item), "_blank");
    });

    /* ── Calendar dropdown toggle ── */
    $(document).on("click", ".cal-btn-trigger", function (e) {
      e.stopPropagation();
      var idx   = $(this).data("idx");
      var $drop = $("#cal-drop-" + idx);
      $(".cal-dropdown").not($drop).removeClass("open");
      $drop.toggleClass("open");
    });

    /* Close dropdown on outside click */
    $(document).on("click", function () {
      $(".cal-dropdown").removeClass("open");
    });

    /* ── Google Calendar ── */
    $(document).on("click", ".google-cal", function (e) {
      e.preventDefault();
      var idx  = parseInt($(this).data("idx"), 10);
      var item = findEventAtIndex(idx);
      if (!item) return;
      window.open(buildGoogleCalUrl(item), "_blank");
      $(".cal-dropdown").removeClass("open");
    });

    /* ── Apple / iCal ── */
    $(document).on("click", ".apple-cal", function (e) {
      e.preventDefault();
      var idx  = parseInt($(this).data("idx"), 10);
      var item = findEventAtIndex(idx);
      if (!item) return;
      downloadIcs(item);
      $(".cal-dropdown").removeClass("open");
    });

    $(document).on("click", ".edc-book-btn", function (e) {
      e.preventDefault();
      e.stopPropagation();
      var idx = parseInt($(this).attr("data-idx"), 10);
      var eid = $(this).attr("data-event-id") || "";
      var item = findEventByKey(isNaN(idx) ? -1 : idx, eid);
      if (!item) return;
      var realIdx = eventRealIndex(item);
      if (realIdx < 0 && !isNaN(idx) && idx >= 0) realIdx = idx;
      handleBookNowClick(item, realIdx);
    });

    $(document).on("click", "#hero-feature-cta", function (e) {
      e.preventDefault();
      var raw = $(this).attr("data-ev-idx");
      if ($(this).is(":disabled") || raw === undefined) return;
      var idx = parseInt(raw, 10);
      if (isNaN(idx) || idx < 0) return;
      var item = findEventAtIndex(idx);
      if (!item) return;
      handleBookNowClick(item, idx);
    });
  }

  /* ── Live countdown ticker (calendar section) ── */
  function startCountdownTicker() {
    setInterval(function () {
      (state.events || []).forEach(function (item, idx) {
        var target = getStartDate(item);
        if (!target) return;
        var diff = target - new Date();
        if (diff <= 0) return;
        var dEl = document.getElementById("cd-d-" + idx);
        if (!dEl) return;
        dEl.textContent = pad2(Math.floor(diff / 86400000));
        document.getElementById("cd-h-" + idx).textContent = pad2(Math.floor((diff % 86400000) / 3600000));
        document.getElementById("cd-m-" + idx).textContent = pad2(Math.floor((diff % 3600000)  / 60000));
        document.getElementById("cd-s-" + idx).textContent = pad2(Math.floor((diff % 60000)    / 1000));
      });
    }, 1000);
  }

  /* ── Init ── */
  function loadCalendar() {
    initCalendarShells();
    if (!$eventsRoot || !$eventsRoot.length) return;

    attachCalendarControls();

    var cfg   = window.CALENDAR_CONFIG || {};
    var calId = cfg.CALENDAR_ID;
    var key   = cfg.API_KEY;

    var googleUrl =
      `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(calId)}/events?key=${key}&singleEvents=true&orderBy=startTime&maxResults=250`;

    function mergeLists(googleItems, localItems) {
      var ga = Array.isArray(googleItems) ? googleItems : [];
      var lo = Array.isArray(localItems) ? localItems : [];
      var out = ga.concat(lo);
      out.sort(function (a, b) {
        var da = getStartDate(a);
        var db = getStartDate(b);
        if (!da && !db) return 0;
        if (!da) return 1;
        if (!db) return -1;
        return da - db;
      });
      return out;
    }

    var OVERLAY_KEYS = ["bookUrl", "imageUrl", "summary", "location", "description"];

    function applyGoogleOverrides_(googleItems, overrides) {
      var o = overrides && typeof overrides === "object" ? overrides : {};
      return (googleItems || []).map(function (it) {
        var p = o[it.id];
        if (!p || typeof p !== "object") return it;
        var out = Object.assign({}, it);
        OVERLAY_KEYS.forEach(function (k) {
          var v = p[k];
          if (v != null && String(v).trim() !== "") out[k] = String(v).trim();
        });
        return out;
      });
    }

    var pg = Promise.resolve([])
      .then(function () {
        if (!calId || !key) return [];
        return fetch(googleUrl)
          .then(function (res) {
            return res.ok ? res.json() : Promise.reject(new Error("google"));
          })
          .then(function (data) {
            return data.items || [];
          })
          .catch(function () {
            return [];
          });
      });

    var pl = fetch("api/events.php", { credentials: "same-origin" })
      .then(function (res) {
        return res.ok ? res.json() : { items: [], overrides: {} };
      })
      .then(function (data) {
        return {
          items: data.items || [],
          overrides: data.overrides && typeof data.overrides === "object" ? data.overrides : {},
        };
      })
      .catch(function () {
        return { items: [], overrides: {} };
      });

    Promise.all([pg, pl])
      .then(function (parts) {
        var googleRaw = parts[0] || [];
        var pack = parts[1] || { items: [], overrides: {} };
        var localItems = pack.items || [];
        var googleMerged = applyGoogleOverrides_(googleRaw, pack.overrides);
        var merged = mergeLists(googleMerged, localItems);
        state.events = merged;
        populateLocationFilter(state.events);
        bindHeroFilters($eventsRoot);
        readFiltersFromForm();
        renderEvents();
        renderHeroSpotlight();
        startCountdownTicker();
      })
      .catch(function () {
        $eventsRoot.html(
          `<p class="calendar-events-msg calendar-events-error">Error loading events.</p>`
        );
      });
  }

  $(function () { loadCalendar(); });

})(jQuery);