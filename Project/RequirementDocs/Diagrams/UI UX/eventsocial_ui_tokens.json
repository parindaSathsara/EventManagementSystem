    "surface": "0 0 0 1px rgba(255,255,255,0.04)",
    "raised": "0 6px 24px rgba(0,0,0,0.35)",
    "overlay": "0 12px 36px rgba(0,0,0,0.45)"
  },
  "motion": {
    "duration": {
      "fast": 120,
      "base": 180,
      "slow": 240
    },
    "easing": {
      "enter": "cubic-bezier(0.2, 0, 0, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)"
    }
