# dependencies
node_modules/

# env (never commit secrets)
.env
.env.local
.env.*.local

# Prisma generated client
prisma/migrations/.tmp/

# logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# build
dist/
build/
coverage/

# User-uploaded files (videos, images). Anchor with leading slash so the
# pattern only matches backend/uploads/ — NOT the source dir
# backend/src/modules/uploads/ which holds the upload-endpoint code.
/uploads/

# local deploy config (gcloud project IDs, instance names)
deploy/.deploy-config
deploy/.env.production.staged
