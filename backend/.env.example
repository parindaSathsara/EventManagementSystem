# =============================================================================
# EventSocial backend — environment template
# Copy to `.env` and fill in real values. `.env` MUST stay gitignored.
# =============================================================================

# Database (production MySQL). The DATABASE_URL string is what Prisma reads.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# URL-encode any special characters in the password (e.g. & = %26).
DATABASE_URL="mysql://root:PASSWORD_URL_ENCODED@35.197.143.222:3306/events"

# Server
PORT=8000
NODE_ENV=development

# CORS — comma-separated list of allowed origins. Use * for dev only.
CORS_ORIGINS=*

# JWT
JWT_SECRET=replace-me-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=30d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Uploads
# Files are written to UPLOAD_DIR and served at /uploads/<filename>.
# PUBLIC_BASE_URL is what gets prefixed when we return the absolute URL to
# the client (used by the mobile app to display the video).
PUBLIC_BASE_URL=http://35.197.143.222:8000
UPLOAD_DIR=./uploads
UPLOAD_MAX_VIDEO_MB=100
UPLOAD_MAX_IMAGE_MB=10

# Optional: seed default admin/artist account when running `npm run db:seed`
SEED_ADMIN_EMAIL=admin@eventsocial.local
SEED_ADMIN_PASSWORD=ChangeMe!2026
