# =============================================================================
# EventSocial backend — production environment template
# Copy to `.env` on the server (NOT committed). Fill every value.
# =============================================================================

NODE_ENV=production
# Default 8011; change if it clashes with another service on the same host.
PORT=8011

# Database — production MySQL.
# URL-encode special chars in the password:
#   & -> %26    + -> %2B    @ -> %40    > -> %3E    = -> %3D
DATABASE_URL="mysql://USER:URL_ENCODED_PASSWORD@35.197.143.222:3306/events"

# CORS — list every origin that should be allowed (mobile apps don't need
# CORS, but if you ever add a web client list it here). Use the comma-
# separated form; `*` is fine only during early demo.
CORS_ORIGINS=https://events-api.aahaas.dev

# JWT — generate with: `openssl rand -hex 32`
JWT_SECRET=REPLACE_ME_WITH_32_PLUS_RANDOM_HEX_BYTES
JWT_EXPIRES_IN=30d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Uploads — written under UPLOAD_DIR, served at /uploads/*
# In prod we use an absolute path so PM2's cwd changes don't move the files.
UPLOAD_DIR=/var/www/events-ai/uploads
UPLOAD_MAX_VIDEO_MB=100
UPLOAD_MAX_IMAGE_MB=10

# PUBLIC_BASE_URL is what gets prefixed to returned upload URLs. Must match
# the address mobile clients use to reach this API.
PUBLIC_BASE_URL=https://events-api.aahaas.dev

# Optional seed account — created by `npm run db:seed`. Change the password
# after the first run, then remove these env vars.
SEED_ADMIN_EMAIL=admin@eventsocial.local
SEED_ADMIN_PASSWORD=ChangeMe-Strong-Password-Here
